# Leave empty to use same-origin /api (recommended for Vercel deployments)
# VITE_API_URL=

# In production, direct cross-origin API is disabled by default for mobile cookie compatibility.
# Set this only if you explicitly need direct API calls in production.
# VITE_ALLOW_DIRECT_API_IN_PROD=true

# Or set an explicit backend URL (must include protocol)
# VITE_API_URL=http://192.168.1.42:5000
# VITE_API_URL=https://my-fleet-app-backend.onrender.com
